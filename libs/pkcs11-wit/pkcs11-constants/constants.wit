  const CKK-CAST: u32 = 0x00000016;
  const CKK-CAST3: u32 = 0x00000017;
  const CKK-CAST5: u32 = 0x00000018;
  const CKK-CAST128: u32 = 0x00000018;  // Alias for CKK-CAST5
  const CKK-RC5: u32 = 0x00000019;
  const CKK-IDEA: u32 = 0x0000001A;
  const CKK-SKIPJACK: u32 = 0x0000001B;
  const CKK-BATON: u32 = 0x0000001C;
  const CKK-JUNIPER: u32 = 0x0000001D;
  const CKK-CDMF: u32 = 0x0000001E;
