package pkcs11:constants@1.0.0;

/// PKCS#11 Standard Constants
/// Based on PKCS#11 v2.40 specification
///
/// This package defines all standard constants used throughout the PKCS#11 API.
/// Applications should use these constants instead of magic numbers for better
/// code clarity and maintainability.

interface constants {
  // ===================================================================
  // Object Classes (CKO_*)
  // ===================================================================

  /// Object class constants define the type of cryptographic object
  const CKO-DATA: u32 = 0x00000000;
  const CKO-CERTIFICATE: u32 = 0x00000001;
  const CKO-PUBLIC-KEY: u32 = 0x00000002;
  const CKO-PRIVATE-KEY: u32 = 0x00000003;
  const CKO-SECRET-KEY: u32 = 0x00000004;
  const CKO-HW-FEATURE: u32 = 0x00000005;
  const CKO-DOMAIN-PARAMETERS: u32 = 0x00000006;
  const CKO-MECHANISM: u32 = 0x00000007;
  const CKO-OTP-KEY: u32 = 0x00000008;
  const CKO-VENDOR-DEFINED: u32 = 0x80000000;

  // ===================================================================
  // Key Types (CKK_*)
  // ===================================================================

  /// Key type constants identify the algorithm/type of a key object
  const CKK-RSA: u32 = 0x00000000;
  const CKK-DSA: u32 = 0x00000001;
  const CKK-DH: u32 = 0x00000002;
  const CKK-ECDSA: u32 = 0x00000003;
