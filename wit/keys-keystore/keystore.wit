// Layer-3 keystore / signer interface: the ceremony-free, component-
// native crypto contract that *applications* consume.
//
// This sits above the faithful Cryptoki projection (`pkcs11-wit`):
//
//   raw softhsm:pkcs11 (C-ABI reflection)          -- provider lift
//     -> pkcs11:* (full idiomatic Cryptoki)         -- driver interface
//       -> keys:keystore (this)                     -- application interface
//
// A provider of this interface (an adapter over any pkcs11 module, a
// pure-software signer, a cloud KMS, ...) hides all of PKCS#11's
// ceremony — sessions, login, object search, mechanism selection —
// behind a handle you can just sign with. Consumers never see a
// session or a PIN; the provider is configured out of band.
//
// Verification is deliberately NOT in this interface: checking a
// signature needs only the public key and the algorithm, so it is
// pure and provider-independent. Consumers verify with their own
// crypto (e.g. ed25519 over `key.public-key()`); making them round-
// trip through a provider to verify would be both slower and a
// needless trust dependency.

package keys:keystore@0.1.0;

interface signer {
    /// Failure modes for key resolution and signing.
    variant error {
        /// No key with the given label exists in this keystore.
        key-not-found(string),
        /// The key or keystore uses an algorithm this build does not
        /// implement.
        unsupported-algorithm(string),
        /// The caller is not permitted to use this key (login failed,
        /// policy denied, key not marked for signing, ...).
        access-denied(string),
        /// Any other provider-side failure (token I/O, internal).
        backend(string),
    }

    /// A handle to a signing key held by the provider.
    ///
    /// Private key material never crosses this boundary — only the
    /// handle and the operations on it. For an HSM-backed provider the
    /// bytes never leave the token at all; for a software provider they
    /// stay inside the provider component.
    resource key {
        /// Signature algorithm identifier, e.g. "ed25519",
        /// "ecdsa-p256", "rsa-pss-sha256". Stable strings so verifiers
        /// can select the matching scheme.
        algorithm: func() -> string;

        /// The public key bytes, in the algorithm's standard raw
        /// encoding (e.g. 32 bytes for ed25519). Consumers use this to
        /// verify signatures themselves.
        public-key: func() -> list<u8>;

        /// Sign `message`, returning the raw signature bytes. The
        /// provider performs whatever ceremony its backend requires
        /// (session, login, C_SignInit/C_Sign) internally.
        sign: func(message: list<u8>) -> result<list<u8>, error>;
    }

    /// Resolve a signing key by opaque label. How the key is located
    /// and unlocked is entirely the provider's concern — a PKCS#11
    /// find-objects + login, a file path, an in-memory key. The label
    /// is the only thing the consumer needs to know.
    get-key: func(label: string) -> result<key, error>;
}

/// World implemented by a keystore provider — an adapter over a
/// pkcs11 module, a software signer, a cloud KMS, etc. Consumers
/// import `signer` rather than targeting this world directly.
world keystore-provider {
    export signer;
}
