package std:attest@1.0.0;

/// Standard attestation interface
///
/// Provides cryptographic attestation of execution artifacts.
/// Hosts can sign execution results and verify attestation proofs.

interface attest {
    /// Attestation algorithm
    enum algorithm {
        ed25519,
        ecdsa-p256,
        rsa-pss,
    }

    /// Attestation claim
    record claim {
        /// Claim type (e.g., "execution", "composition")
        claim-type: string,
        /// Plan digest
        plan-digest: list<u8>,
        /// Artifact digest (composed component or exec result)
        artifact-digest: list<u8>,
        /// Execution key (for exec attestations)
        exec-key: option<list<u8>>,
        /// Timestamp when attestation was created
        timestamp: u64,
        /// Host identifier
        host-id: string,
        /// Additional claims (JSON-encoded)
        custom-claims: option<string>,
    }

    /// Attestation proof
    record attestation {
        /// The claim being attested
        claim: claim,
        /// Signature algorithm used
        algorithm: algorithm,
        /// Cryptographic signature
        signature: list<u8>,
        /// Public key of signer (DER-encoded)
        public-key: list<u8>,
        /// Certificate chain (optional, for PKI)
        cert-chain: option<list<list<u8>>>,
    }

    /// Verification result
    record verification-result {
        /// Whether signature is valid
        valid: bool,
        /// Signer identity
        signer: string,
        /// Verification timestamp
        verified-at: u64,
        /// Error message if invalid
        error: option<string>,
    }

    /// Create an attestation for a claim
    attest: func(
        claim: claim,
        algorithm: algorithm
    ) -> result<attestation, string>;

    /// Verify an attestation proof
    verify: func(
        attestation: attestation
    ) -> result<verification-result, string>;

    /// Get host public key
    get-public-key: func(
        algorithm: algorithm
    ) -> result<list<u8>, string>;

    /// Export attestation to standard format (e.g., SLSA, in-toto)
    export-attestation: func(
        attestation: attestation,
        format: string
    ) -> result<string, string>;
}
