package std:secrets@1.0.0;

/// Standard secrets interface with pluggable backend support
/// Implements token-based indirection model (Model C)

interface types {
    /// Opaque secret token handle
    /// Components receive tokens, never actual secret values
    type secret-token = string;

    /// Secret identifier in plan or configuration
    type secret-id = string;

    /// Backend URI scheme (e.g., "pkcs11://", "vault://", "dev://")
    type backend-uri = string;

    /// Error codes for secret operations
    variant secret-error {
        /// Secret not found in backend
        not-found,
        /// Access denied to secret
        access-denied,
        /// Backend operation failed
        backend-error,
        /// Invalid token
        invalid-token,
        /// Secret has expired
        expired,
        /// Invalid backend URI
        invalid-backend,
    }

    /// Secret metadata
    record secret-metadata {
        /// Secret identifier
        id: secret-id,
        /// Backend URI
        backend: backend-uri,
        /// Creation timestamp (Unix seconds)
        created-at: option<u64>,
        /// Expiration timestamp (Unix seconds)
        expires-at: option<u64>,
        /// Additional backend-specific metadata
        metadata: option<string>,
    }
}

/// Secrets interface for host implementation
interface secrets {
    use types.{secret-token, secret-id, backend-uri, secret-error, secret-metadata};
    /// Resolve a secret ID to an opaque token
    /// The host looks up the secret in the configured backend
    /// and returns a token that can be used to access it
    resolve: func(id: secret-id, backend: backend-uri) -> result<secret-token, secret-error>;

    /// Get secret value by token (only accessible to host)
    /// Components should never call this directly
    get-value: func(token: secret-token) -> result<list<u8>, secret-error>;

    /// Validate that a token is still valid
    validate-token: func(token: secret-token) -> result<bool, secret-error>;

    /// Revoke a token (invalidate it)
    revoke-token: func(token: secret-token) -> result<_, secret-error>;

    /// Get metadata about a secret
    get-metadata: func(token: secret-token) -> result<secret-metadata, secret-error>;

    /// List available secret IDs (for admin/debugging)
    list-secrets: func(backend: option<backend-uri>) -> result<list<secret-id>, secret-error>;
}

/// Backend configuration interface
interface backend {
    use types.{backend-uri, secret-error};

    /// Backend configuration record
    record backend-config {
        /// Backend URI scheme
        uri: backend-uri,
        /// Backend-specific configuration (JSON)
        config: string,
    }

    /// Register a secret backend
    register-backend: func(config: backend-config) -> result<_, secret-error>;

    /// Unregister a secret backend
    unregister-backend: func(uri: backend-uri) -> result<_, secret-error>;

    /// Check if a backend is available
    has-backend: func(uri: backend-uri) -> bool;

    /// List registered backends
    list-backends: func() -> list<backend-uri>;
}
